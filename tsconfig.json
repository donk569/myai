{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@dudu/shared/*": ["shared/*/src"],
      "@dudu/storage": ["shared/storage/src"],
      "@dudu/character-system": ["shared/character-system/src"],
      "@dudu/chat-engine": ["shared/chat-engine/src"]
    }
  },
  "exclude": ["node_modules", "dist", "out"]
}
